{
  "name": "Trakt Scrobbler",
  "identifier": "io.github.fahim.iinatraktscrobbler",
  "version": "0.1.34",
  "author": {
    "name": "Fahim"
  },
  "ghRepo": "i3p9/iina-trakt-scrobbler",
  "ghVersion": "0.1.34",
  "entry": "main.js",
  "description": "A Trakt scrobbler plugin for IINA.",
  "sidebarTab": {
    "name": "Trakt"
  },
  "permissions": [
    "show-osd",
    "network-request",
    "file-system"
  ],
  "allowedDomains": [
    "api.trakt.tv",
    "trakt.tv"
  ],
  "preferencesPage": "preferences.html",
  "preferenceDefaults": {
    "trakt_client_id": "",
    "trakt_client_secret": "",
    "scrobble_enabled": true,
    "status_osd": true,
    "debug_osd": false,
    "skip_interval": 5,
    "preview_threshold": 80,
    "preview_duration": 60,
    "fast_pause_threshold": 1,
    "fast_pause_duration": 5,
    "auth_state": "disconnected",
    "auth_summary": "Not connected to Trakt",
    "auth_detail": "Use Connect to start device authorization.",
    "auth_busy": false,
    "auth_connected": false,
    "auth_credential_mode": "",
    "auth_updated_at": "",
    "auth_action_kind": "",
    "auth_action_nonce": ""
  }
}
